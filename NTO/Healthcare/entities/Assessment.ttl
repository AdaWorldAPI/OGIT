@prefix ogit:               <http://www.purl.org/ogit/> .
@prefix ogit.Healthcare:    <http://www.purl.org/ogit/Healthcare/> .
@prefix owl:                <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:               <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms:            <http://purl.org/dc/terms/> .
@prefix xsd:                <http://www.w3.org/2001/XMLSchema#> .

# ─────────────────────────────────────────────────────────────────────
# Assessment — the reusable, modality-agnostic diagnostic-evaluation
# sub-tree. The `is_a` rail is the modality taxonomy (sonography / MRI /
# histology are all a kind of Assessment); the `part_of` rail grounds a
# concrete assessment onto the FMA anatomy it evaluates (e.g. a Joint).
# Grounded in the standard clinical ontology (SNOMED CT), NOT in any
# application's schema — a consumer app binds its own form as a private
# render label over these public coordinates.
# ─────────────────────────────────────────────────────────────────────

ogit.Healthcare:Assessment
	a rdfs:Class;
	rdfs:subClassOf ogit:Entity;
	rdfs:label "Assessment";
	dcterms:description "A diagnostic evaluation act that produces findings about an anatomical structure. Modality-agnostic root: an assessment is performed by some modality (its is_a subclass) and evaluates some anatomical structure (its part_of grounding).";
	dcterms:source "SNOMED-CT:386053000";
	dcterms:creator "claude-ogit-bootstrap";
	ogit:scope "NTO";
	ogit:parent ogit:Node;
	ogit:mandatory-attributes (
		ogit:id
	);
	ogit:optional-attributes (
		ogit.Healthcare:performedAt
		ogit.Healthcare:findingSummary
	);
	ogit:indexed-attributes (
		ogit.Healthcare:performedAt
	);
	ogit:allowed (
			[ ogit:assesses  ogit.Healthcare:AnatomicalStructure ]
			[ ogit:belongs   ogit.Healthcare:Patient ]
	);
.

# ── is_a rail — the modality taxonomy (each modality is-a Assessment) ──

ogit.Healthcare:SonographicAssessment
	a rdfs:Class;
	rdfs:subClassOf ogit.Healthcare:Assessment;
	rdfs:label "SonographicAssessment";
	dcterms:description "An assessment performed by ultrasound (sonography). Reusable across any sonographic examination; the assessed structure is fixed by the part_of grounding (e.g. a joint, an abdomen), never by the modality.";
	dcterms:source "SNOMED-CT:16310003";
	dcterms:creator "claude-ogit-bootstrap";
	ogit:scope "NTO";
	ogit:parent ogit.Healthcare:Assessment;
	ogit:allowed (
			[ ogit:assesses  ogit.Healthcare:AnatomicalStructure ]
	);
.

ogit.Healthcare:MriAssessment
	a rdfs:Class;
	rdfs:subClassOf ogit.Healthcare:Assessment;
	rdfs:label "MriAssessment";
	dcterms:description "An assessment performed by magnetic-resonance imaging. Same reusable shape as SonographicAssessment — a different modality over the identical anatomy grounding.";
	dcterms:source "SNOMED-CT:113091000";
	dcterms:creator "claude-ogit-bootstrap";
	ogit:scope "NTO";
	ogit:parent ogit.Healthcare:Assessment;
	ogit:allowed (
			[ ogit:assesses  ogit.Healthcare:AnatomicalStructure ]
	);
.

ogit.Healthcare:HistologicAssessment
	a rdfs:Class;
	rdfs:subClassOf ogit.Healthcare:Assessment;
	rdfs:label "HistologicAssessment";
	dcterms:description "An assessment performed by histopathological examination of tissue. The third modality sibling; reuses the Assessment root and the anatomy grounding at zero additional shape cost.";
	dcterms:source "SNOMED-CT:250537006";
	dcterms:creator "claude-ogit-bootstrap";
	ogit:scope "NTO";
	ogit:parent ogit.Healthcare:Assessment;
	ogit:allowed (
			[ ogit:assesses  ogit.Healthcare:AnatomicalStructure ]
	);
.

# ── shared agnostic properties ──

ogit.Healthcare:performedAt
	a ogit:Property;
	rdfs:label "performedAt";
	dcterms:description "Timestamp at which the assessment was performed.";
	dcterms:source "SNOMED-CT:386053000";
	ogit:type "xsd:dateTime" .

ogit.Healthcare:findingSummary
	a ogit:Property;
	rdfs:label "findingSummary";
	dcterms:description "Free-text or coded summary of the assessment's finding. Structured per-site findings are cascade-path nodes part_of the assessment, not a codebook slot.";
	dcterms:source "SNOMED-CT:404684003";
	ogit:type "xsd:string" .
