@prefix ogit:               <http://www.purl.org/ogit/> .
@prefix ogit.Medical:       <http://www.purl.org/ogit/Medical/> .
@prefix rdfs:               <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms:            <http://purl.org/dc/terms/> .
@prefix xsd:                <http://www.w3.org/2001/XMLSchema#> .

ogit.Medical:PfDiagnosis
    a rdfs:Class ;
    rdfs:subClassOf ogit:Entity ;
    rdfs:label "PfDiagnosis" ;
    rdfs:comment "Patient-form diagnosis row binding an ICD code, label, free text, and lead/chronic-diagnosis flags (ld/kd) to the patient timeline." ;
    dcterms:source "AdaWorldAPI/MedCare-rs/.MYSQL/Struktur.sql:pf_diagnosis" ;
    ogit:scope "NTO" ;
    ogit:parent ogit:Node ;
    ogit:loaderStatus "stub" ;
    ogit:columnCount 17 ;
    ogit:primaryKey "id" ;
    ogit:mysqlTable "pf_diagnosis" .
