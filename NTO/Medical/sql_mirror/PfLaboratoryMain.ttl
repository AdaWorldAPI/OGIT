ogit.Medical:PfLaboratoryMain
    a rdfs:Class ;
    rdfs:subClassOf ogit:Entity ;
    rdfs:label "PfLaboratoryMain" ;
    rdfs:comment "Patient-form laboratory-order header: per-patient lab request with date, status, type, and notice that owns a set of pf_laboratory_values rows." ;
    dcterms:source "AdaWorldAPI/MedCare-rs/.MYSQL/Struktur.sql:pf_laboratory_main" ;
    ogit:scope "NTO" ;
    ogit:parent ogit:Node ;
    ogit:loaderStatus "stub" ;
    ogit:columnCount 14 ;
    ogit:primaryKey "id" ;
    ogit:mysqlTable "pf_laboratory_main" .
